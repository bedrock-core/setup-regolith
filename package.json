{
  "name": "setup-regolith",
  "version": "1.0.0",
  "description": "GitHub Action to download the Regolith CLI and add it to PATH",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js",
    "package": "yarn build",
    "test:act": "act workflow_dispatch -W .github/workflows/test-setup-regolith.yml -j smoke-test -P ubuntu-latest=node:20-bullseye"
  },
  "keywords": [
    "github",
    "actions",
    "regolith",
    "minecraft",
    "bedrock",
    "addons"
  ],
  "author": "DrAv0011",
  "contributors": [
    {
      "name": "DrAv0011",
      "email": "contact@drav.dev",
      "url": "https://drav.dev"
    }
  ],
  "license": "MIT",
  "packageManager": "yarn@4.11.0",
  "devDependencies": {
    "@types/node": "^25.6.2",
    "esbuild": "latest",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/tool-cache": "^4.0.0"
  }
}
